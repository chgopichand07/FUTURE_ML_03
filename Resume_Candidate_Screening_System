print("Average Match Score :",
      round(df["Match Score"].mean(),2))

print("Highest Match Score :",
      round(df["Match Score"].max(),2))

print("Lowest Match Score :",
      round(df["Match Score"].min(),2))

# ----------------------------------------------------------
# Score Categories
# ----------------------------------------------------------

excellent = len(df[df["Status"]=="Excellent Match"])

strong = len(df[df["Status"]=="Strong Match"])

good = len(df[df["Status"]=="Good Match"])

poor = len(df[df["Status"]=="Needs Improvement"])

print("\nExcellent Matches :",excellent)

print("Strong Matches :",strong)

print("Good Matches :",good)

print("Needs Improvement :",poor)

print("\nPart 2 Completed Successfully!")
