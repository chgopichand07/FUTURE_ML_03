    autopct="%1.1f%%",
    startangle=90
)

plt.title("Candidate Status Distribution")

plt.show()

# ----------------------------------------------------------
# Most Common Skills
# ----------------------------------------------------------

all_skills = []

for skills in ranking["Matched Skills"]:

    for skill in skills.split(","):

        skill = skill.strip()

        if skill != "":
            all_skills.append(skill)

counter = Counter(all_skills)

top = counter.most_common(10)

skill_df = pd.DataFrame(
    top,
    columns=[
        "Skill",
        "Frequency"
    ]
)

plt.figure(figsize=(10,5))

plt.bar(
    skill_df["Skill"],
    skill_df["Frequency"]
)

plt.title("Top Skills Found in Candidates")

plt.xlabel("Skill")

plt.ylabel("Frequency")

plt.grid(axis="y")

plt.show()

