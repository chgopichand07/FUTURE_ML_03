import pandas as pd
import numpy as np
import re
import nltk
import matplotlib.pyplot as plt

from nltk.corpus import stopwords
from sklearn.feature_extraction.text import TfidfVectorizer

nltk.download("stopwords")

print("="*60)
print("RESUME SCREENING SYSTEM")
print("="*60)

# ----------------------------------------------------------
# Job Description
# ----------------------------------------------------------

job_description = """
Looking for a Machine Learning Intern.

Required Skills:

Python
Machine Learning
Deep Learning
Pandas
NumPy
Scikit Learn
TensorFlow
SQL
Data Analysis
Statistics
Git
Communication
Problem Solving
"""

# ----------------------------------------------------------
# Resume Dataset
# ----------------------------------------------------------

resumes = [

{
"name":"Rahul",
"resume":"Python Machine Learning Pandas NumPy Scikit Learn SQL Git Data Analysis Communication"
},

{
"name":"Priya",
"resume":"Java HTML CSS JavaScript React SQL Git Teamwork Communication"
},

{
"name":"Arjun",
"resume":"Python Deep Learning TensorFlow Keras Pandas Machine Learning Statistics SQL"
},

{
"name":"Sneha",
"resume":"Python Data Analysis Excel Power BI SQL Statistics Pandas"
},

{
"name":"Kiran",
"resume":"Machine Learning Python NumPy Pandas TensorFlow Deep Learning Git SQL"
},

{
"name":"Anjali",
"resume":"Java Spring Boot MySQL HTML CSS Bootstrap"
},

{
"name":"Vikram",
"resume":"Python Machine Learning Artificial Intelligence Data Analysis Statistics Communication"
},

{
"name":"Keerthi",
"resume":"Python SQL Git Pandas NumPy Machine Learning Data Visualization"
},

{
"name":"Rohit",
"resume":"C C++ Java Operating Systems Computer Networks DBMS"
},

{
"name":"Divya",
"resume":"Python Machine Learning TensorFlow SQL Statistics Git Pandas NumPy Communication"
}

]

df = pd.DataFrame(resumes)

print("\nCandidate Dataset")

print(df)

# ----------------------------------------------------------
# Text Cleaning
# ----------------------------------------------------------

stop_words = set(stopwords.words("english"))

def clean_text(text):

    text = text.lower()

    text = re.sub(r'[^a-zA-Z ]',' ',text)

    words = text.split()

    words = [word for word in words if word not in stop_words]

    return " ".join(words)

df["Clean_Resume"] = df["resume"].apply(clean_text)

job_clean = clean_text(job_description)

print("\nCleaned Resume Example\n")

print(df[["name","Clean_Resume"]])

# ----------------------------------------------------------
# TF-IDF Vectorization
# ----------------------------------------------------------

vectorizer = TfidfVectorizer()

resume_vectors = vectorizer.fit_transform(
    df["Clean_Resume"]
)

job_vector = vectorizer.transform(
    [job_clean]
)

print("\nTF-IDF Matrix Shape")

print(resume_vectors.shape)

print("\nPart 1 Completed Successfully!")
# ==========================================================
# PART 2 : Resume Similarity, Ranking & Skill Gap Analysis
# ==========================================================

from sklearn.metrics.pairwise import cosine_similarity

print("\n" + "="*60)
print("RESUME MATCHING & CANDIDATE RANKING")
print("="*60)

# ----------------------------------------------------------
# Calculate Cosine Similarity
# ----------------------------------------------------------

similarity_scores = cosine_similarity(
    resume_vectors,
    job_vector
)

df["Match Score"] = (
    similarity_scores.flatten() * 100
).round(2)

# ----------------------------------------------------------
# Skill Extraction
# ----------------------------------------------------------

required_skills = [
    "python",
    "machine",
    "learning",
    "deep",
    "tensorflow",
    "pandas",
    "numpy",
    "scikit",
    "sql",
    "statistics",
    "git",
    "communication",
    "problem",
    "solving",
    "analysis"
]

candidate_skills = []

missing_skills = []

for resume in df["Clean_Resume"]:

    skills_found = []

    skills_missing = []

    for skill in required_skills:

        if skill in resume:

            skills_found.append(skill)

        else:

            skills_missing.append(skill)

    candidate_skills.append(", ".join(skills_found))

    missing_skills.append(", ".join(skills_missing))

df["Matched Skills"] = candidate_skills

df["Missing Skills"] = missing_skills

# ----------------------------------------------------------
# Candidate Status
# ----------------------------------------------------------

status = []

for score in df["Match Score"]:

    if score >= 80:

        status.append("Excellent Match")

    elif score >= 60:

        status.append("Strong Match")

    elif score >= 40:

        status.append("Good Match")

    else:

        status.append("Needs Improvement")

df["Status"] = status

# ----------------------------------------------------------
# Ranking Candidates
# ----------------------------------------------------------

ranking = df.sort_values(
    by="Match Score",
    ascending=False
).reset_index(drop=True)

ranking.index += 1

ranking.index.name = "Rank"

print("\nCandidate Ranking\n")

print(
    ranking[
        [
            "name",
            "Match Score",
            "Status"
        ]
    ]
)

# ----------------------------------------------------------
# Best Candidate
# ----------------------------------------------------------

best = ranking.iloc[0]

print("\n" + "="*60)

print("BEST CANDIDATE")

print("="*60)

print("Name :", best["name"])

print("Match Score :", best["Match Score"], "%")

print("Status :", best["Status"])

# ----------------------------------------------------------
# Missing Skills Report
# ----------------------------------------------------------

print("\n" + "="*60)

print("SKILL GAP ANALYSIS")

print("="*60)

for i,row in ranking.iterrows():

    print("\nCandidate :",row["name"])

    print("Matched Skills :")

    print(row["Matched Skills"])

    print("\nMissing Skills :")

    print(row["Missing Skills"])

    print("-"*50)

